# Block access to secret-bearing files and directories even in trusted projects.
# These rules are intentionally more restrictive than the general read allowances.
# Rules only match exact argument prefixes. Complex shell one-liners with
# redirection or globs may still require an explicit rule if Codex cannot split them.

# forbidden: dotenv files
prefix_rule(
    pattern = [
        ["ls", "ll", "la", "tree", "fd", "sed", "cat", "head", "tail", "less", "bat", "du", "wc", "stat", "file", "readlink", "realpath"],
        [".env", "./.env"],
    ],
    decision = "forbidden",
    justification = "Do not read dotenv files. Use non-secret docs or examples instead.",
)

# forbidden: secrets directories
prefix_rule(
    pattern = [
        ["ls", "ll", "la", "tree", "fd", "sed", "cat", "head", "tail", "less", "bat", "du", "wc", "stat", "file", "readlink", "realpath"],
        ["secrets", "./secrets"],
    ],
    decision = "forbidden",
    justification = "Do not read files under secrets/. Use redacted fixtures or documented examples instead.",
)

# forbidden: common secret directories
prefix_rule(
    pattern = [
        ["ls", "ll", "la", "tree", "fd", "sed", "cat", "head", "tail", "less", "bat", "du", "wc", "stat", "file", "readlink", "realpath"],
        ["credentials", "envs", "private", "certs", "keys", "vault", ".ssh", ".gnupg", ".aws", ".kube", ".pki", "./credentials", "./envs", "./private", "./certs", "./keys", "./vault", "./.ssh", "./.gnupg", "./.aws", "./.kube", "./.pki"],
    ],
    decision = "forbidden",
    justification = "Do not read common secret directories. Use sanitized fixtures or documented examples instead.",
)

# allow: read-only file and directory inspection
prefix_rule(
    pattern = [["pwd", "ls", "ll", "la", "tree", "fd", "sed", "cat", "head", "tail", "less", "bat", "du", "wc", "stat", "file", "readlink", "realpath"]],
    decision = "allow",
    justification = "Read-only filesystem inspection is safe to run without approval unless a forbidden path rule matches first.",
)

# allow: guarded search wrappers
prefix_rule(
    pattern = ["agent-rg"],
    decision = "allow",
    justification = "agent-rg blocks rg preprocessors and is safe for read-only search.",
)

prefix_rule(
    pattern = ["agent-find"],
    decision = "allow",
    justification = "agent-find blocks mutating find primaries and is safe for read-only traversal.",
)

# allow: VCS and repository metadata inspection
prefix_rule(
    pattern = ["git", ["status", "diff", "log", "show", "branch", "remote", "rev-parse", "ls-files"]],
    decision = "allow",
    justification = "Git metadata inspection is safe to run without approval.",
)

prefix_rule(
    pattern = ["gh", ["repo", "pr", "issue"], ["view", "list", "status"]],
    decision = "allow",
    justification = "GitHub metadata inspection is safe to run without approval.",
)

# allow: package metadata inspection
prefix_rule(
    pattern = ["npm", ["view", "info", "ls", "list", "outdated", "--version"]],
    decision = "allow",
    justification = "Package metadata inspection is safe to run without approval.",
)

prefix_rule(
    pattern = ["pnpm", ["view", "info", "ls", "list", "why", "outdated", "-v", "--version"]],
    decision = "allow",
    justification = "Package metadata inspection is safe to run without approval.",
)

prefix_rule(
    pattern = ["yarn", ["info", "why", "list", "--version"]],
    decision = "allow",
    justification = "Package metadata inspection is safe to run without approval.",
)

prefix_rule(
    pattern = ["pip", ["show", "list", "freeze", "--version"]],
    decision = "allow",
    justification = "Python package metadata inspection is safe to run without approval.",
)

# allow: Python test and coverage execution
prefix_rule(
    pattern = ["pytest"],
    decision = "allow",
    justification = "Running Python test suites is safe to run without approval.",
)

prefix_rule(
    pattern = [["python", "python3"], "-m", ["pytest", "coverage"]],
    decision = "allow",
    justification = "Running Python test and coverage modules is safe to run without approval.",
)

prefix_rule(
    pattern = [["uv", "poetry"], "run", ["pytest", "coverage"]],
    decision = "allow",
    justification = "Running Python test and coverage modules is safe to run without approval.",
)

prefix_rule(
    pattern = ["coverage", ["run", "report", "html", "xml"]],
    decision = "allow",
    justification = "Running Python coverage commands is safe to run without approval.",
)

# allow: JavaScript and browser test execution
prefix_rule(
    pattern = [["npm", "pnpm", "yarn"], ["test", "lint", "typecheck", "format", "format:check"]],
    decision = "allow",
    justification = "Common project validation commands are safe to run without approval.",
)

prefix_rule(
    pattern = [["npm", "pnpm", "yarn"], "run", ["test", "test:unit", "test:integration", "test:e2e", "test:ci", "test:watch", "test:coverage", "coverage", "lint", "typecheck", "format", "format:check", "prettier", "playwright", "test:playwright", "e2e"]],
    decision = "allow",
    justification = "Common project script execution for validation is safe to run without approval.",
)

prefix_rule(
    pattern = ["npx", ["jest", "vitest", "playwright"]],
    decision = "allow",
    justification = "Running JavaScript and browser test runners is safe to run without approval.",
)

prefix_rule(
    pattern = ["pnpm", ["jest", "vitest"]],
    decision = "allow",
    justification = "Running JavaScript and browser test runners is safe to run without approval.",
)

prefix_rule(
    pattern = ["bun", ["test", "playwright"]],
    decision = "allow",
    justification = "Running JavaScript and browser test runners is safe to run without approval.",
)

# allow: common tool version and help output
prefix_rule(
    pattern = [["node", "npm", "pnpm", "yarn", "python", "python3", "ruby", "go", "rustc", "cargo", "bun", "uv", "poetry", "docker", "docker-compose", "kubectl", "brew", "gh", "git", "tmux", "fish", "zsh", "bash"], ["-v", "-V", "--version", "version", "help", "--help"]],
    decision = "allow",
    justification = "Version and help output are safe to run without approval.",
)

# allow: validation, diagnostics, and local policy inspection
prefix_rule(
    pattern = ["shellcheck"],
    decision = "allow",
    justification = "Shell script static analysis is safe to run without approval.",
)

prefix_rule(
    pattern = [["bash", "zsh", "fish"], "-n"],
    decision = "allow",
    justification = "Shell syntax checks are safe to run without approval.",
)

prefix_rule(
    pattern = ["sort"],
    decision = "allow",
    justification = "Sorting stdin is safe to run without approval.",
)

prefix_rule(
    pattern = ["sleep", "20"],
    decision = "allow",
    justification = "Short waits are safe to run without approval.",
)

prefix_rule(
    pattern = ["test", "-f"],
    decision = "allow",
    justification = "File existence checks are safe to run without approval.",
)

prefix_rule(
    pattern = ["mise", "exec", "--", ["pnpm", "npm"], ["lint", "typecheck"]],
    decision = "allow",
    justification = "Lint and typecheck commands are safe to run without approval.",
)

prefix_rule(
    pattern = ["codex", "execpolicy"],
    decision = "allow",
    justification = "Local execpolicy inspection is safe to run without approval.",
)

# allow: docker compose validation workflows
prefix_rule(
    pattern = ["docker", "compose", "ps"],
    decision = "allow",
    justification = "Container status inspection is safe to run without approval.",
)

prefix_rule(
    pattern = ["docker", "compose", "exec", ["app", "e2e"], "pnpm", ["test", "test:unit", "test:e2e", "lint", "typecheck", "format", "format:check", "prettier"]],
    decision = "allow",
    justification = "Running validation commands inside existing containers is safe to run without approval.",
)

prefix_rule(
    pattern = ["docker", "compose", "run", "--rm", ["app", "e2e"], "pnpm", ["test", "test:unit", "test:e2e", "lint", "typecheck", "format", "format:check", "prettier"]],
    decision = "allow",
    justification = "Running one-shot validation commands inside containers is safe to run without approval.",
)

prefix_rule(
    pattern = ["docker", "compose", "up", "-d", "app"],
    decision = "allow",
    justification = "Starting the local app service for validation is safe to run without approval.",
)

prefix_rule(
    pattern = ["docker", "compose", "restart", "app"],
    decision = "allow",
    justification = "Restarting the local app service for validation is safe to run without approval.",
)
prefix_rule(pattern=["docker", "compose", "exec", "e2e", "pnpm", "test:e2e"], decision="allow")
